---
import BaseLayout from '../layouts/BaseLayout.astro';

const socials = [
  { label: 'Email', href: 'mailto:you@example.com', display: 'you@example.com' },
  { label: 'GitHub', href: 'https://github.com', display: 'github.com/yourhandle' },
  { label: 'LinkedIn', href: 'https://linkedin.com', display: 'linkedin.com/in/yourhandle' },
];
---

<BaseLayout title="Contact — NØPE" description="Get in touch.">
  <section class="page-shell layout-shell">
    <div class="page-grid layout-grid">
      <h1 class="page-title visually-hidden">Contact</h1>
    <div class="contact-body">
      <p class="contact-intro">
        The best way to reach me is via email. I'm also on a few other places:
      </p>
      <ul class="contact-list">
        {socials.map(({ label, href, display }) => (
          <li class="contact-item">
            <span class="contact-item__label">{label}</span>
            <a href={href} class="contact-item__link" target="_blank" rel="noopener">{display}</a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    grid-column: 1 / 4;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding-top: 0.2em;
  }

  .contact-body {
    grid-column: 4 / 9;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .contact-intro {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
  }

  .contact-item__label {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    min-width: 72px;
  }

  .contact-item__link {
    font-size: var(--font-size-base);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .contact-item__link:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .page-grid {
      grid-template-columns: 1fr;
    }

    .page-title,
    .contact-body {
      grid-column: 1;
    }

    .page-title {
      margin-bottom: var(--space-6);
    }
  }
</style>
