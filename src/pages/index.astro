---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_TITLE } from "../config";
---

<BaseLayout
  title={SITE_TITLE}
  description="Design, websites, and digital work for ordinary people and small companies. Made by people."
>
  <section class="hero">
    <div class="hero__shell layout-shell">
      <div class="hero__grid layout-grid">
        <h1 class="hero__wordmark">{SITE_TITLE}</h1>
        <p class="hero__explainer">
          we say <strong>no</strong> to most things. When we say <strong
            >yes</strong
          >, we mean it.
          <em>Websites.</em>
          <em>Apps.</em>
          <em>Design.</em> For folks who want it done right.
        </p>
        <nav class="hero__actions">
          <a href="/work" class="hero__cta hero__cta--primary">See work</a>
          <a href="/contact" class="hero__cta hero__cta--secondary">Say hello</a
          >
        </nav>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 100dvh;
    display: flex;
    position: relative;
    isolation: isolate;
  }

  .hero__shell {
    flex: 1;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero__grid {
    width: 100%;
    min-height: 100%;
    align-content: center;
    row-gap: var(--space-6);
    padding-block: var(--space-16);
  }

  .hero__wordmark {
    grid-column: 1 / 10;
    font-size: var(--font-size-display);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
  }

  .hero__explainer {
    grid-column: 1 / 6;
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .hero__actions {
    grid-column: 1 / 5;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-6);
  }

  .hero__cta {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.1s ease;
  }

  .hero__cta--primary {
    color: var(--color-text-primary);
  }

  .hero__cta--primary:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .hero__cta--secondary {
    color: var(--color-text-secondary);
  }

  .hero__cta--secondary:hover {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero__grid {
      row-gap: var(--space-4);
      padding-block: var(--space-12);
    }

    .hero__wordmark,
    .hero__explainer {
      grid-column: 1 / -1;
    }

    .hero__actions {
      grid-column: 1 / -1;
    }

    .hero__explainer {
      font-size: var(--font-size-sm);
    }
  }
</style>
