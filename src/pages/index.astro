---
import BaseLayout from "../layouts/BaseLayout.astro";
import LiftButton from "../components/LiftButton.astro";
---

<BaseLayout
  title="NOPE"
  description="Design, websites, and digital work for ordinary people and small companies. Made by people."
>
  <section class="hero">
    <div class="hero__shell layout-shell">
      <div class="hero__grid layout-grid">
        <div class="hero__copy">
          <h1 class="hero__title">
            <span
              class="hero__title-word hero__title-word--human"
              style="--word-index: 0"
            ><span class="hero__title-letter" style="--letter-rotate: -5deg; --letter-skew: -3deg">H</span><span class="hero__title-letter" style="--letter-rotate: 4deg; --letter-skew: 4deg">u</span><span class="hero__title-letter" style="--letter-rotate: -3deg; --letter-skew: 2deg">m</span><span class="hero__title-letter hero__title-letter--wiggle" style="--letter-rotate: 6deg; --letter-skew: -4deg">a</span><span class="hero__title-letter" style="--letter-rotate: -4deg; --letter-skew: 3deg">n</span><span class="hero__title-dot">.</span>
            </span>
            <span
              class="hero__title-word hero__title-word--minimal"
              style="--word-index: 1"
            >
              Minimal<span class="hero__title-dot">.</span>
            </span>
            <span
              class="hero__title-word hero__title-word--deliberate"
              style="--word-index: 2"
            >
<span class="hero__deliberate-letter" style="--i:0">D</span><span class="hero__deliberate-letter" style="--i:1">e</span><span class="hero__deliberate-letter" style="--i:2">l</span><span class="hero__deliberate-letter" style="--i:3">i</span><span class="hero__deliberate-letter" style="--i:4">b</span><span class="hero__deliberate-letter" style="--i:5">e</span><span class="hero__deliberate-letter" style="--i:6">r</span><span class="hero__deliberate-letter" style="--i:7">a</span><span class="hero__deliberate-letter" style="--i:8">t</span><span class="hero__deliberate-letter" style="--i:9">e</span><span class="hero__title-dot">.</span>
            </span>
          </h1>
          <p class="hero__summary">
            Websites. Apps. Design. <br />
            Not sure what you need yet. <br />
            That's fine. Most people aren't. <br />
            Say hello and we'll figure it out.
          </p>
          <p class="hero__summary"></p>
          <nav class="hero__actions">
            <LiftButton
              href="mailto:hello@nope.digital"
              variant="primary"
              experimentalTextColor={true}
            >
              Say hello
            </LiftButton>
            <LiftButton href="/work" variant="secondary">See work</LiftButton>
          </nav>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>


<style>
  .hero {
    flex: 1;
    min-height: 0;
    display: flex;
    position: relative;
    isolation: isolate;
  }

  .hero__shell {
    flex: 1;
    position: relative;
    z-index: 2;
  }

  .hero__grid {
    width: 100%;
    min-height: 100%;
    grid-template-rows: auto 1fr;
    align-items: start;
    row-gap: var(--space-8);
    padding-top: var(--space-20);
    padding-bottom: var(--space-20);
  }

  .hero__copy {
    grid-column: 3 / 9;
    grid-row: 2;
    display: grid;
    row-gap: var(--space-6);
    align-content: start;
  }

  @keyframes hero-word-in {
    from {
      opacity: 0;
      translate: 0 0.4em;
      scale: 0.92;
    }
    to {
      opacity: 1;
      translate: 0 0;
      scale: 1;
    }
  }

  .hero__title-word {
    display: block;
    --hero-title-word-weight: var(--font-weight-bold);
    --hero-title-word-hover-weight: var(--font-weight-bold);
    --hero-title-word-transition-duration:
      var(--motion-duration-hero-weight-shift);
    --hero-title-word-transition-ease: var(--motion-ease-hero-weight-shift);
    min-inline-size: var(--hero-title-word-min-width, auto);
    font-variation-settings: "wght" var(--hero-title-word-weight);
    animation:
      hero-word-in
      var(--motion-duration-hero-reveal)
      calc(var(--word-index) * var(--hero-word-stagger))
      var(--motion-ease-footer-spring)
      both;
    transition:
      font-variation-settings var(--hero-title-word-transition-duration)
      var(--hero-title-word-transition-ease);
  }

  .hero__title-word--human {
    --hero-title-word-transition-duration: var(--motion-duration-hero-human);
    --hero-title-word-transition-ease: var(--motion-ease-hero-human);
    --hero-title-word-min-width: 5.2ch;
    cursor: inherit;
  }

  .hero__title-word--minimal {
    --hero-title-word-hover-weight: var(--font-weight-thin);
    --hero-title-word-transition-duration: var(--motion-duration-hero-minimal);
    --hero-title-word-transition-ease: var(--motion-ease-hero-minimal);
    --hero-title-word-min-width: 7.4ch;
    cursor: inherit;
  }

  .hero__title-word--deliberate {
    --hero-title-word-transition-duration:
      var(--motion-duration-hero-deliberate);
    --hero-title-word-transition-ease: var(--motion-ease-hero-deliberate);
    --hero-title-word-min-width: 10ch;
    cursor: inherit;
  }

  @media (hover: hover) and (pointer: fine) {
    .hero__title-word:hover {
      --hero-title-word-weight: var(--hero-title-word-hover-weight);
    }
  }

  .hero__title-dot {
    color: var(--color-accent-experimental);
  }

  @keyframes letter-wiggle {
    0%   { transform: rotate(6deg) skewX(-4deg) translateY(0.15em); }
    25%  { transform: rotate(-7deg) skewX(5deg) translateY(0.2em); }
    50%  { transform: rotate(8deg) skewX(-3deg) translateY(0.15em); }
    75%  { transform: rotate(-5deg) skewX(4deg) translateY(0.18em); }
    100% { transform: rotate(6deg) skewX(-4deg) translateY(0.15em); }
  }

  .hero__deliberate-letter {
    display: inline-block;
    font-variation-settings: "wght" var(--font-weight-bold);
    transition: font-variation-settings 0.2s var(--motion-ease-hero-deliberate) calc(var(--i) * 40ms);
  }

  @media (hover: hover) and (pointer: fine) {
    .hero__title-word--deliberate:hover .hero__deliberate-letter {
      font-variation-settings: "wght" var(--font-weight-black);
    }
  }

  .hero__title-letter {
    display: inline-block;
    transition: transform var(--motion-duration-hero-human) var(--motion-ease-hero-human);
  }

  @media (hover: hover) and (pointer: fine) {
    .hero__title-word--human.is-hovered .hero__title-letter {
      transform: rotate(var(--letter-rotate)) skewX(var(--letter-skew));
    }

    .hero__title-word--human.is-hovered .hero__title-letter--wiggle {
      animation: letter-wiggle 1.4s ease-in-out infinite;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__title-word {
      animation: none;
      transition: none;
    }
  }

  .hero__title {
    max-width: 9ch;
    font-size: clamp(4.2rem, 8vw, 7rem);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-display);
    letter-spacing: -0.03em;
    text-indent: -0.03em;
    text-wrap: balance;
    color: var(--color-text-primary);
  }

  .hero__title-break {
    display: block;
    color: color-mix(
      in srgb,
      var(--color-text-primary) 84%,
      var(--neutral-500)
    );
  }

  .hero__summary {
    max-width: 28rem;
    font-size: var(--font-size-lg);
    line-height: var(--line-height-snug);
    text-wrap: pretty;
    color: color-mix(
      in srgb,
      var(--color-text-primary) 72%,
      var(--neutral-500)
    );
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    justify-self: start;
    padding-top: var(--space-2);
  }

  @media (max-width: 640px) {
    .hero {
      min-height: auto;
    }

    .hero__grid {
      min-height: auto;
      grid-template-rows: auto;
      row-gap: var(--space-6);
      padding-top: var(--space-8);
      padding-bottom: var(--space-10);
    }

    .hero__eyebrow,
    .hero__copy,
    .hero__actions {
      grid-column: 1 / -1;
      grid-row: auto;
      justify-self: stretch;
      align-self: auto;
    }

    .hero__title {
      max-width: 11ch;
      font-size: clamp(3rem, 15vw, 4.5rem);
    }

    .hero__actions {
      justify-content: flex-start;
    }
  }
</style>

<script>
  function init() {
    const word = document.querySelector(".hero__title-word--human");
    if (!word) return;

    const wiggleLetter = word.querySelector(".hero__title-letter--wiggle") as HTMLElement | null;

    word.addEventListener("mouseenter", () => {
      if (wiggleLetter) wiggleLetter.style.transform = "";
      word.classList.add("is-hovered");
    });

    word.addEventListener("mouseleave", () => {
      if (wiggleLetter) {
        // Snapshot current animated position so transition starts from here
        const current = getComputedStyle(wiggleLetter).transform;
        wiggleLetter.style.transform = current;
        // Force reflow so the browser registers the inline style
        wiggleLetter.offsetWidth;
      }
      word.classList.remove("is-hovered");
      if (wiggleLetter) {
        // Clear inline style after a tick so the transition runs to the CSS default
        requestAnimationFrame(() => {
          wiggleLetter.style.transform = "";
        });
      }
    });
  }

  document.addEventListener("astro:page-load", init);
</script>
