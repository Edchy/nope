---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="NOPE"
  description="Design, websites, and digital work for ordinary people and small companies. Made by people."
>
  <section class="hero">
    <div class="hero__shell layout-shell">
      <div class="hero__grid layout-grid">
        <div class="hero__copy">
          <h1 class="hero__title">Minimal. Considered. Human.</h1>
          <p class="hero__summary">
            Websites. Apps. Design. <br /> Fast. Honest. Built to last.
          </p>
          <p class="hero__summary"></p>
          <nav class="hero__actions">
            <a href="/work" class="hero__cta hero__cta--primary">See work</a>
            <a href="/contact" class="hero__cta hero__cta--secondary">Say hello</a>
          </nav>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    flex: 1;
    min-height: 0;
    display: flex;
    position: relative;
    isolation: isolate;
  }

  .hero__shell {
    flex: 1;
    position: relative;
    z-index: 2;
  }

  .hero__grid {
    width: 100%;
    min-height: 100%;
    grid-template-rows: auto 1fr;
    align-items: start;
    row-gap: var(--space-8);
    padding-top: var(--space-20);
    padding-bottom: var(--space-20);
  }

  .hero__copy {
    grid-column: 2 / 8;
    grid-row: 2;
    display: grid;
    row-gap: var(--space-6);
    align-content: start;
  }

  .hero__title {
    max-width: 9ch;
    font-size: clamp(4.2rem, 8vw, 7rem);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-display);
    letter-spacing: -0.06em;
    text-wrap: balance;
    color: var(--color-text-primary);
  }

  .hero__title-break {
    display: block;
    color: color-mix(
      in srgb,
      var(--color-text-primary) 84%,
      var(--neutral-500)
    );
  }

  .hero__summary {
    max-width: 28rem;
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    text-wrap: pretty;
    color: color-mix(
      in srgb,
      var(--color-text-primary) 72%,
      var(--neutral-500)
    );
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    justify-self: start;
    padding-top: var(--space-2);
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 10rem;
    padding-inline: var(--space-6);
    padding-block: var(--space-3);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition:
      color 0.1s ease,
      background-color 0.1s ease,
      box-shadow 0.1s ease;
  }

  .hero__cta--primary {
    background-color: var(--color-action-primary);
    color: var(--color-text-inverse);
  }

  .hero__cta--primary:hover {
    background-color: var(--color-action-primary-hover);
    color: var(--color-text-inverse);
    text-decoration: none;
  }

  .hero__cta--secondary {
    color: var(--color-text-primary);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
  }

  .hero__cta--secondary:hover {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero {
      min-height: auto;
    }

    .hero__grid {
      min-height: auto;
      grid-template-rows: auto;
      row-gap: var(--space-6);
      padding-top: var(--space-8);
      padding-bottom: var(--space-10);
    }

    .hero__eyebrow,
    .hero__copy,
    .hero__actions {
      grid-column: 1 / -1;
      grid-row: auto;
      justify-self: stretch;
      align-self: auto;
    }

    .hero__title {
      max-width: 11ch;
      font-size: clamp(3rem, 15vw, 4.5rem);
    }

    .hero__summary {
      font-size: var(--font-size-base);
    }

    .hero__actions {
      justify-content: flex-start;
    }
  }
</style>
