---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="NOPE"
  description="Design, websites, and digital work for ordinary people and small companies. Made by people."
>
  <section class="hero">
    <div class="hero__shell layout-shell">
      <div class="hero__grid layout-grid">
        <p class="hero__explainer">
          Websites. Apps. Design. <br />
          Minimal. Considered. Human. <br />
          For small companies and people who want it done properly.
        </p>
        <nav class="hero__actions">
          <a href="/work" class="hero__cta hero__cta--primary">See work</a>
          <a href="/contact" class="hero__cta hero__cta--secondary">Say hello</a
          >
        </nav>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    flex: 1;
    min-height: 0;
    display: flex;
    position: relative;
    isolation: isolate;
  }

  .hero__shell {
    flex: 1;
    position: relative;
    z-index: 2;
  }

  .hero__grid {
    width: 100%;
    min-height: 100%;
    grid-template-rows: auto 1fr auto;
    align-items: start;
    row-gap: var(--space-6);
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .hero__explainer {
    grid-column: 2 / 6;
    grid-row: 1;
    justify-self: start;
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    text-align: left;
  }

  .hero__actions {
    grid-column: 4 / 10;
    grid-row: 2;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    justify-self: center;
    align-self: center;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 11rem;
    padding-inline: var(--space-6);
    padding-block: var(--space-3);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition:
      color 0.1s ease,
      background-color 0.1s ease,
      box-shadow 0.1s ease;
  }

  .hero__cta--primary {
    background-color: var(--color-action-primary);
    color: var(--color-text-inverse);
  }

  .hero__cta--primary:hover {
    background-color: var(--color-action-primary-hover);
    color: var(--color-text-inverse);
    text-decoration: none;
  }

  .hero__cta--secondary {
    background-color: transparent;
    box-shadow: inset 0 0 0 var(--border-width-1) var(--color-text-primary);
    color: var(--color-text-primary);
  }

  .hero__cta--secondary:hover {
    background-color: var(--color-background-surface);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero {
      min-height: auto;
    }

    .hero__grid {
      min-height: auto;
      grid-template-rows: none;
      row-gap: var(--space-6);
      padding-top: var(--space-8);
      padding-bottom: var(--space-10);
    }

    .hero__explainer,
    .hero__actions {
      grid-column: 1 / -1;
      grid-row: auto;
      justify-self: stretch;
      align-self: auto;
    }

    .hero__explainer {
      font-size: var(--font-size-sm);
      text-align: left;
    }

    .hero__actions {
      justify-content: flex-start;
    }
  }
</style>
