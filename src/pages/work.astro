---
import BaseLayout from "../layouts/BaseLayout.astro";
import LiftSurface from "../components/LiftSurface.astro";

const featuredProjects = [
  {
    name: "Bakkerij Hartog",
    type: "Website",
    year: "2025",
    color: "#c8b89a",
    desc: "A warm, neighbourhood bakery website with online ordering and seasonal menus.",
    tags: ["Astro", "E-commerce", "CMS"],
    href: "#",
  },
  {
    name: "Forma Studio",
    type: "Branding",
    year: "2025",
    color: "#b8c4bb",
    desc: "Brand identity for a minimal furniture studio — wordmark, palette, and print system.",
    tags: ["Identity", "Print", "Art direction"],
    href: "#",
  },
  {
    name: "Kin",
    type: "App",
    year: "2024",
    color: "#a9b8c8",
    desc: "A family coordination app for shared schedules, tasks, and household notes.",
    tags: ["Product design", "iOS", "Figma"],
    href: "#",
  },
  {
    name: "Lund Collective",
    type: "Website",
    year: "2024",
    color: "#c4b8c8",
    desc: "Portfolio site for a Malmö-based creative collective spanning film, photo, and design.",
    tags: ["Astro", "Motion", "Editorial"],
    href: "#",
  },
];

const archiveProjects = [
  {
    name: "Palma",
    type: "Branding",
    year: "2024",
  },
  {
    name: "Ström",
    type: "Website",
    year: "2023",
  },
  {
    name: "North Shelf",
    type: "Identity",
    year: "2023",
  },
  {
    name: "Mar Row",
    type: "Campaign",
    year: "2022",
  },
  {
    name: "Ateljé Norr",
    type: "Website",
    year: "2022",
  },
];
---

<BaseLayout title="Work — NøPE" description="Selected work.">
  <section class="page-shell layout-shell work-page">
    <div class="page-grid layout-grid">
      <h1 class="page-title visually-hidden">Work</h1>
      <div class="work-section work-section-featured">
        <p class="section-label">Selected work</p>
        <p class="section-intro">
          A small edit of recent projects across websites, identities, and
          digital products.
        </p>
        <ul class="work-list">
          {
            featuredProjects.map(({ name, type, year, color, desc, tags, href }) => (
              <li class="work-item work-item-featured">
                <LiftSurface href={href} class="work-item-link">
                  <span
                    data-color={color}
                    data-desc={desc}
                    data-type={type}
                    data-year={year}
                    data-tags={tags.join(",")}
                    class="work-item-main"
                  >
                    <h3 class="project-name">{name}</h3>
                    <span class="project-meta">
                      <span class="project-type">{type}</span>
                      <span class="project-year">{year}</span>
                    </span>
                  </span>
                </LiftSurface>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="work-section work-section-archive">
        <p class="section-label">Archive</p>
        <p class="section-intro">
          Smaller commissions, earlier systems, and work that still belongs in
          the index.
        </p>
        <ul class="work-list">
          {
            archiveProjects.map(({ name, type, year }) => (
              <li class="work-item work-item-archive">
                <div class="work-item-main">
                  <h3 class="project-name">{name}</h3>
                  <span class="project-meta">
                    <span class="project-type">{type}</span>
                    <span class="project-year">{year}</span>
                  </span>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Floating preview -->
<div class="preview" id="preview">
  <div class="preview-swatch" id="preview-swatch"></div>
  <div class="preview-body">
    <p class="preview-desc" id="preview-desc"></p>
    <ul class="preview-tags" id="preview-tags"></ul>
  </div>
</div>

<style>
  :global([data-theme="experimental"]) .work-page {
    --color-text-primary: var(--color-text-inverse);
    --color-text-secondary: var(--color-text-inverse);
    color: var(--color-text-primary);
  }

  .work-page .page-grid {
    row-gap: var(--space-8);
  }

  .work-page .page-title {
    grid-column: 1 / 4;
    align-self: start;
    min-width: 0;
    width: 100%;
    max-width: 42rem;
    margin-inline: auto;
    padding-top: 0.2em;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .work-page .work-section {
    grid-column: 3 / 11;
    display: block;
  }

  .work-section-archive {
    margin-top: var(--space-16);
  }

  .section-label {
    margin: 0 0 var(--space-2) 0;
    font-size: var(--font-size-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    opacity: 0.65;
  }

  .section-intro {
    max-width: 28rem;
    margin: 0 0 var(--space-8) 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-snug);
    color: var(--color-text-primary);
    text-wrap: pretty;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .work-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-6);
    width: 100%;
  }

  .work-item-main {
    display: flex;
    width: 100%;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-6);
    flex: 1;
    min-width: 0;
  }

  .work-item-link {
    display: block;
    width: 100%;
    text-decoration: none;
    color: inherit;
    outline-offset: var(--space-2);
  }

  .work-item-archive {
    color: var(--color-text-secondary);
  }

  .project-name {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-regular);
    letter-spacing: -0.02em;
    line-height: var(--line-height-tight);
    color: var(--color-text-primary);
    text-wrap: pretty;
  }

  .work-item-archive .project-name {
    font-size: var(--font-size-base);
    letter-spacing: -0.01em;
    color: var(--color-text-secondary);
  }

  .project-meta {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: flex-end;
    flex-shrink: 0;
    opacity: 0.72;
  }

  .project-type {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    min-width: 4rem;
  }

  .project-year {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    min-width: 2.5rem;
    text-align: right;
  }

  .work-item-featured {
    position: relative;
  }

  .preview {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 100;
    opacity: 0;
    transition: opacity 0.18s ease;
    will-change: transform, opacity;
    display: flex;
    align-items: stretch;
    background: var(--color-background-surface);
    color: var(--neutral-900);
    width: 320px;
    overflow: hidden;
  }

  .preview.visible {
    opacity: 1;
  }

  .preview-swatch {
    width: 80px;
    flex-shrink: 0;
    transition: background-color 0.2s ease;
  }

  .preview-body {
    flex: 1;
    min-width: 0;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .preview-desc {
    margin: 0;
    font-size: var(--font-size-xs);
    line-height: var(--line-height-relaxed);
    color: currentColor;
  }

  .preview-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    margin-top: auto;
  }

  .preview-tags li {
    font-size: var(--font-size-xs);
    color: currentColor;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .preview-tags li:not(:last-child)::after {
    content: "·";
    margin-left: var(--space-1);
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .work-page .page-title {
      grid-column: 1 / -1;
    }

    .work-page .work-section {
      grid-column: 1 / -1;
    }

    .section-intro {
      max-width: none;
      margin-bottom: var(--space-6);
    }
  }

  @media (max-width: 500px) {
    .project-year {
      display: none;
    }
  }
</style>

<script>
  let cleanupWorkPreview: (() => void) | undefined;

  const canUseDesktopPreview = () =>
    window.matchMedia("(min-width: 769px)").matches &&
    window.matchMedia("(hover: hover) and (pointer: fine)").matches;

  function initWorkPreview() {
    cleanupWorkPreview?.();

    const items = document.querySelectorAll(
      ".work-item-featured .work-item-main",
    );
    const preview = document.getElementById("preview");
    const swatch = document.getElementById("preview-swatch");
    const desc = document.getElementById("preview-desc");
    const tags = document.getElementById("preview-tags");

    if (!items.length || !preview) {
      cleanupWorkPreview = undefined;
      return;
    }

    if (!canUseDesktopPreview()) {
      preview.classList.remove("visible");
      cleanupWorkPreview = undefined;
      return;
    }

    let mouseX = 0;
    let mouseY = 0;
    let rafId: number | null = null;
    const controller = new AbortController();
    const { signal } = controller;

    const updatePreviewPosition = () => {
      const vw = window.innerWidth;
      const pw = preview.offsetWidth;
      const offset = 28;
      const x = mouseX + offset + pw > vw ? mouseX - pw - offset : mouseX + offset;
      preview.style.transform = `translate(${x}px, calc(${mouseY}px - 50%))`;
      preview.style.left = "0";
      preview.style.top = "0";
    };

    const handleMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;

      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(updatePreviewPosition);
    };

    document.addEventListener("mousemove", handleMouseMove, { signal });

    items.forEach((item) => {
      item.addEventListener(
        "mouseenter",
        () => {
          const el = item as HTMLElement;
          const color = el.dataset.color;
          const text = el.dataset.desc;
          const tagList = el.dataset.tags?.split(",") ?? [];

          if (swatch) swatch.style.backgroundColor = color ?? "";
          if (desc) desc.textContent = text ?? "";
          if (tags) {
            tags.innerHTML = tagList
              .map((t) => `<li>${t.trim()}</li>`)
              .join("");
          }
          preview.classList.add("visible");
        },
        { signal },
      );

      item.addEventListener(
        "mouseleave",
        () => {
          preview.classList.remove("visible");
        },
        { signal },
      );
    });

    cleanupWorkPreview = () => {
      controller.abort();
      preview.classList.remove("visible");
      if (rafId) cancelAnimationFrame(rafId);
    };
  }

  document.addEventListener("astro:page-load", initWorkPreview);
  initWorkPreview();
</script>
