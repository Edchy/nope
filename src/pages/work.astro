---
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredProjects = [
  {
    name: "Bakkerij Hartog",
    type: "Website",
    year: "2025",
    img: "eddie.avif",
    desc: "A warm, neighbourhood bakery website with online ordering and seasonal menus.",
  },
  {
    name: "Forma Studio",
    type: "Branding",
    year: "2025",
    img: "images/project-2.jpg",
    desc: "Brand identity for a minimal furniture studio — wordmark, palette, and print system.",
  },
  {
    name: "Kin",
    type: "App",
    year: "2024",
    img: "images/project-3.jpg",
    desc: "A family coordination app for shared schedules, tasks, and household notes.",
  },
  {
    name: "Lund Collective",
    type: "Website",
    year: "2024",
    img: "images/project-4.jpg",
    desc: "Portfolio site for a Malmö-based creative collective spanning film, photo, and design.",
  },
];

const archiveProjects = [
  {
    name: "Palma",
    type: "Design",
    year: "2024",
  },
  {
    name: "Ström",
    type: "Website",
    year: "2023",
  },
  {
    name: "North Shelf",
    type: "Identity",
    year: "2023",
  },
  {
    name: "Mar Row",
    type: "Campaign",
    year: "2022",
  },
  {
    name: "Ateljé Norr",
    type: "Website",
    year: "2022",
  },
];
---

<BaseLayout title="Work — NøPE" description="Selected work.">
  <section class="page-shell layout-shell work-page">
    <div class="page-grid layout-grid">
      <h1 class="page-title visually-hidden">Work</h1>
      <div class="work-section work-section-featured">
        <p class="section-label">Selected work</p>
        <div class="work-list">
          {
            featuredProjects.map(({ name, type, year, img, desc }) => (
              <div class="work-item work-item-featured" data-img={img} data-desc={desc}>
                <span class="project-name">{name}</span>
                <span class="project-meta">
                  <span class="project-type">{type}</span>
                  <span class="project-year">{year}</span>
                </span>
              </div>
            ))
          }
        </div>
      </div>
      <div class="work-section work-section-archive">
        <p class="section-label">Archive</p>
        <p class="archive-intro">
          Smaller commissions, earlier systems, and work that still belongs in the index.
        </p>
        {
          archiveProjects.map(({ name, type, year }) => (
            <div class="work-item work-item-archive">
              <span class="project-name">{name}</span>
              <span class="project-meta">
                <span class="project-type">{type}</span>
                <span class="project-year">{year}</span>
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Floating preview -->
<div class="preview" id="preview">
  <img id="preview-img" src="" alt="" />
  <p id="preview-desc"></p>
</div>

<style>
  .page-title {
    grid-column: 1 / 4;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding-top: 0.2em;
  }

  .work-list {
    grid-column: 3 / 10;
  }

  .work-section {
    grid-column: 3 / 10;
  }

  .work-section-archive {
    margin-top: var(--space-16);
  }

  .section-label {
    margin: 0 0 var(--space-6);
    font-size: var(--font-size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .archive-intro {
    max-width: 28rem;
    margin: 0 0 var(--space-6);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  .work-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-6);
  }

  .work-item-featured {
    padding: var(--space-3) 0;
    cursor: crosshair;
    user-select: none;
  }

  .work-item-featured:hover .project-name {
    transform: translateX(var(--space-2));
  }

  .work-item-archive {
    padding: var(--space-2) 0;
    color: var(--color-text-secondary);
  }

  .project-name {
    font-size: 1.3rem;
    font-weight: var(--font-weight-regular);
    letter-spacing: -0.02em;
    transition: transform 0.2s ease;
    color: var(--color-text-primary);
  }

  .work-item-archive .project-name {
    font-size: var(--font-size-base);
    letter-spacing: -0.01em;
    color: var(--color-text-secondary);
  }

  .project-meta {
    display: flex;
    gap: var(--space-8);
    align-items: baseline;
    flex-shrink: 0;
  }

  .project-type {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    min-width: 4rem;
  }

  .project-year {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    min-width: 2.5rem;
    text-align: right;
  }

  .preview {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 100;
    opacity: 0;
    transition: opacity 0.18s ease;
    transform: translate(28px, -50%);
    will-change: transform, opacity;
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: var(--neutral-100);
    padding: var(--space-3);
  }

  .preview.visible {
    opacity: 0.9;
  }

  .preview img {
    width: 240px;
    height: 170px;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
  }

  #preview-desc {
    width: 160px;
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    padding-top: 2px;
  }

  @media (max-width: 640px) {
    .page-grid {
      grid-template-columns: 1fr;
    }

    .page-title,
    .work-list,
    .work-section {
      grid-column: 1;
    }

    .page-title {
      margin-bottom: var(--space-6);
    }

    .work-section-archive {
      margin-top: var(--space-12);
    }

    .archive-intro {
      max-width: none;
    }

    .work-item {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-1);
    }

    .project-name {
      font-size: 1.1rem;
    }

    .work-item-archive .project-name {
      font-size: var(--font-size-sm);
    }

    .project-meta {
      gap: var(--space-4);
    }

    .preview {
      display: none;
    }
  }
</style>

<script>
  let cleanupWorkPreview: (() => void) | undefined;

  function initWorkPreview() {
    cleanupWorkPreview?.();

    const items = document.querySelectorAll(".work-item-featured");
    const preview = document.getElementById("preview");
    const img = document.getElementById("preview-img") as HTMLImageElement | null;
    const desc = document.getElementById("preview-desc");

    if (!items.length || !preview || !img) {
      cleanupWorkPreview = undefined;
      return;
    }

    let mouseX = 0;
    let mouseY = 0;
    let rafId: number | null = null;
    const controller = new AbortController();
    const { signal } = controller;

    const updatePreviewPosition = () => {
      preview.style.transform = `translate(${mouseX + 28}px, calc(${mouseY}px - 50%))`;
      preview.style.left = "0";
      preview.style.top = "0";
    };

    const handleMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;

      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(updatePreviewPosition);
    };

    document.addEventListener("mousemove", handleMouseMove, { signal });

    items.forEach((item) => {
      item.addEventListener(
        "mouseenter",
        () => {
          const el = item as HTMLElement;
          const src = el.dataset.img;
          const text = el.dataset.desc;

          if (!src) return;

          img.src = src;
          if (desc) desc.textContent = text ?? "";
          preview.classList.add("visible");
        },
        { signal },
      );

      item.addEventListener(
        "mouseleave",
        () => {
          preview.classList.remove("visible");
        },
        { signal },
      );
    });

    cleanupWorkPreview = () => {
      controller.abort();
      preview.classList.remove("visible");
      if (rafId) cancelAnimationFrame(rafId);
    };
  }

  document.addEventListener("astro:page-load", initWorkPreview);
  initWorkPreview();
</script>
