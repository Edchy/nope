---
import BaseLayout from "../layouts/BaseLayout.astro";
import LiftSurface from "../components/LiftSurface.astro";

const featuredProjects = [
  {
    name: "Bakkerij Hartog",
    type: "Website",
    year: "2025",
    img: "eddie.avif",
    desc: "A warm, neighbourhood bakery website with online ordering and seasonal menus.",
    href: "#",
  },
  {
    name: "Forma Studio",
    type: "Branding",
    year: "2025",
    img: "images/project-2.jpg",
    desc: "Brand identity for a minimal furniture studio — wordmark, palette, and print system.",
    href: "#",
  },
  {
    name: "Kin",
    type: "App",
    year: "2024",
    img: "images/project-3.jpg",
    desc: "A family coordination app for shared schedules, tasks, and household notes.",
    href: "#",
  },
  {
    name: "Lund Collective",
    type: "Website",
    year: "2024",
    img: "images/project-4.jpg",
    desc: "Portfolio site for a Malmö-based creative collective spanning film, photo, and design.",
    href: "#",
  },
];

const archiveProjects = [
  {
    name: "Palma",
    type: "Design",
    year: "2024",
  },
  {
    name: "Ström",
    type: "Website",
    year: "2023",
  },
  {
    name: "North Shelf",
    type: "Identity",
    year: "2023",
  },
  {
    name: "Mar Row",
    type: "Campaign",
    year: "2022",
  },
  {
    name: "Ateljé Norr",
    type: "Website",
    year: "2022",
  },
];
---

<BaseLayout title="Work — NøPE" description="Selected work.">
  <section class="page-shell layout-shell work-page">
    <div class="page-grid layout-grid">
      <h1 class="page-title visually-hidden">Work</h1>
      <div class="work-section work-section-featured">
        <p class="section-label">Selected work</p>
        <p class="section-intro">
          A small edit of recent projects across websites, identities, and
          digital products.
        </p>
        <div class="work-list">
          {
            featuredProjects.map(({ name, type, year, img, desc, href }) => (
              <article class="work-item work-item-featured">
                <LiftSurface href={href} class="work-item-link">
                  <span data-img={img} data-desc={desc} class="work-item-main">
                    <span class="project-name">{name}</span>
                    <span class="project-meta">
                      <span class="project-type">{type}</span>
                      <span class="project-year">{year}</span>
                    </span>
                  </span>
                </LiftSurface>
              </article>
            ))
          }
        </div>
      </div>
      <div class="work-section work-section-archive">
        <p class="section-label">Archive</p>
        <p class="section-intro">
          Smaller commissions, earlier systems, and work that still belongs in
          the index.
        </p>
        <div class="work-list">
          {
            archiveProjects.map(({ name, type, year }) => (
              <article class="work-item work-item-archive">
                <div class="work-item-main">
                  <span class="project-name">{name}</span>
                  <span class="project-meta">
                    <span class="project-type">{type}</span>
                    <span class="project-year">{year}</span>
                  </span>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Floating preview -->
<div class="preview" id="preview">
  <img id="preview-img" src="" alt="" />
  <p id="preview-desc"></p>
</div>

<style>
  .page-title {
    grid-column: 1 / 4;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding-top: 0.2em;
  }

  .work-list {
    grid-column: 3 / 11;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .work-section {
    grid-column: 3 / 11;
  }

  .work-section-archive {
    margin-top: var(--space-16);
  }

  .section-label {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .section-intro {
    max-width: 28rem;
    margin: 0 0 var(--space-6);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  .work-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-6);
    width: 100%;
  }

  .work-item-featured {
    position: relative;
    cursor: crosshair;
    user-select: none;
  }

  .work-item-featured::before {
    content: "";
    position: absolute;
    left: calc(var(--space-8) * -1);
    top: 50%;
    width: var(--space-2);
    height: var(--border-width-2);
    background-color: var(--neutral-900);
    opacity: 0;
    transform: translateY(-50%);
    transition:
      opacity 0.18s ease,
      width 0.18s var(--motion-ease-decelerate);
  }

  .work-item-featured .project-name,
  .work-item-featured .project-meta {
    transition:
      color 0.18s ease,
      opacity 0.18s ease;
  }

  .work-item-featured:focus-within::before {
    width: var(--space-6);
    opacity: 1;
  }

  .work-item-featured:focus-visible .project-name {
    color: color-mix(
      in srgb,
      var(--color-text-primary) 82%,
      var(--neutral-500)
    );
  }

  .work-item-featured:focus-visible .project-meta {
    opacity: 1;
  }

  @media (hover: hover) and (pointer: fine) {
    .work-item-featured:hover::before {
      width: var(--space-6);
      opacity: 1;
    }

    .work-item-featured:hover .project-name {
      color: color-mix(
        in srgb,
        var(--color-text-primary) 82%,
        var(--neutral-500)
      );
    }

    .work-item-featured:hover .project-meta {
      opacity: 1;
    }
  }

  .work-item-main {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-6);
    flex: 1;
    min-width: 0;
    width: 100%;
  }

  .work-item-link {
    display: block;
    width: 100%;
    text-decoration: none;
    color: inherit;
  }

  .work-item-archive {
    color: var(--color-text-secondary);
  }

  .project-name {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-regular);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .work-item-archive .project-name {
    font-size: var(--font-size-base);
    letter-spacing: -0.01em;
    color: var(--color-text-secondary);
  }

  .project-meta {
    display: flex;
    gap: var(--space-8);
    align-items: baseline;
    flex-shrink: 0;
    opacity: 0.72;
  }

  .project-type {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    min-width: 4rem;
  }

  .project-year {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    min-width: 2.5rem;
    text-align: right;
  }

  @media (prefers-reduced-motion: reduce) {
    .work-item-featured::before,
    .work-item-featured .project-name,
    .work-item-featured .project-meta {
      transition: none;
    }
  }

  .preview {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 100;
    opacity: 0;
    transition: opacity 0.18s ease;
    transform: translate(28px, -50%);
    will-change: transform, opacity;
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: var(--neutral-100);
    padding: var(--space-3);
  }

  .preview.visible {
    opacity: 0.9;
  }

  .preview img {
    width: 240px;
    height: 170px;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
  }

  #preview-desc {
    width: 160px;
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    padding-top: 2px;
  }

  @media (max-width: 768px) {
    .page-title,
    .work-list,
    .work-section {
      grid-column: 1 / -1;
    }

    .work-section {
      display: grid;
      row-gap: var(--space-4);
      width: min(100%, 42rem);
      margin-inline: auto;
    }

    .work-section-archive {
      margin-top: var(--space-10);
    }

    .section-intro {
      max-width: none;
      margin-bottom: var(--space-4);
    }

    .work-list {
      gap: var(--space-6);
    }

    .work-item {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-2);
    }

    .work-item-main {
      width: 100%;
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-2);
    }

    .project-name {
      font-size: var(--font-size-lg);
    }

    .work-item-archive .project-name {
      font-size: var(--font-size-base);
    }

    .section-label {
      font-size: var(--font-size-sm);
    }

    .section-intro {
      font-size: var(--font-size-base);
    }

    .project-meta {
      gap: var(--space-3);
    }

    .project-type,
    .project-year {
      min-width: 0;
      text-align: left;
    }

    .work-item-featured {
      cursor: default;
      user-select: auto;
    }

    .work-item-featured::before {
      display: none;
    }

    .preview {
      display: none;
    }
  }
</style>

<script>
  let cleanupWorkPreview: (() => void) | undefined;

  const canUseDesktopPreview = () =>
    window.matchMedia("(min-width: 769px)").matches &&
    window.matchMedia("(hover: hover) and (pointer: fine)").matches;

  function initWorkPreview() {
    cleanupWorkPreview?.();

    const items = document.querySelectorAll(
      ".work-item-featured .work-item-main",
    );
    const preview = document.getElementById("preview");
    const img = document.getElementById(
      "preview-img",
    ) as HTMLImageElement | null;
    const desc = document.getElementById("preview-desc");

    if (!items.length || !preview || !img) {
      cleanupWorkPreview = undefined;
      return;
    }

    if (!canUseDesktopPreview()) {
      preview.classList.remove("visible");
      cleanupWorkPreview = undefined;
      return;
    }

    let mouseX = 0;
    let mouseY = 0;
    let rafId: number | null = null;
    const controller = new AbortController();
    const { signal } = controller;

    const updatePreviewPosition = () => {
      preview.style.transform = `translate(${mouseX + 28}px, calc(${mouseY}px - 50%))`;
      preview.style.left = "0";
      preview.style.top = "0";
    };

    const handleMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;

      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(updatePreviewPosition);
    };

    document.addEventListener("mousemove", handleMouseMove, { signal });

    items.forEach((item) => {
      item.addEventListener(
        "mouseenter",
        () => {
          const el = item as HTMLElement;
          const src = el.dataset.img;
          const text = el.dataset.desc;

          if (!src) return;

          img.src = src;
          if (desc) desc.textContent = text ?? "";
          preview.classList.add("visible");
        },
        { signal },
      );

      item.addEventListener(
        "mouseleave",
        () => {
          preview.classList.remove("visible");
        },
        { signal },
      );
    });

    cleanupWorkPreview = () => {
      controller.abort();
      preview.classList.remove("visible");
      if (rafId) cancelAnimationFrame(rafId);
    };
  }

  document.addEventListener("astro:page-load", initWorkPreview);
  initWorkPreview();
</script>
