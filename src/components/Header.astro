---
import { SITE_TITLE } from "../config";

const navLinks = [
  { href: "/work", label: "Work" },
  { href: "/about", label: "Studio" },
  { href: "#", label: "Blog", isExternal: true },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__shell layout-shell">
    <div class="site-header__grid layout-grid">
      <a href="/" class="site-header__logo" aria-label={`${SITE_TITLE} home`}
        >{SITE_TITLE} STUDIO.</a
      >
      <nav class="site-header__nav" aria-label="Main navigation">
        <ul class="site-header__links">
          {
            navLinks.map(({ href, label, isExternal }) => (
              <li>
                <a
                  href={href}
                  class:list={[
                    "site-header__link",
                    { "site-header__link--active": currentPath === href },
                  ]}
                >
                  <span>{label}</span>
                  {isExternal && (
                    <span
                      class="site-header__external-indicator"
                      aria-hidden="true"
                    >
                      ↗
                    </span>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
        <button
          id="theme-toggle"
          class="site-header__theme-toggle"
          aria-label="Toggle experimental theme"></button>
      </nav>
    </div>
  </div>
</header>

<style>
  .site-header {
    background-color: transparent;
  }

  .site-header__shell {
    padding-block: var(--space-4);
  }

  .site-header__grid {
    align-items: center;
  }

  /* Logo: columns 1–2 */
  .site-header__logo {
    grid-column: 3 / 5;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    text-decoration: none;
    line-height: 1;
  }

  .site-header__logo:hover {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  /* Nav: columns 7–12, right-aligned */
  .site-header__nav {
    grid-column: 5 / 11;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-6);
  }

  .site-header__links {
    display: flex;
    gap: var(--space-8);
    list-style: none;
  }

  .site-header__link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-1);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.1s ease;
  }

  .site-header__link:hover,
  .site-header__link--active {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .site-header__external-indicator {
    font-size: 0.95em;
    line-height: 1;
    transform: translateY(-0.08em);
  }

  .site-header__theme-toggle {
    width: 20px;
    height: 20px;
    border-radius: var(--border-radius-full);
    background-color: var(--button-theme-toggle-color);
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.15s ease;
  }

  @media (max-width: 640px) {
    .site-header__grid {
      grid-template-columns: 1fr 1fr;
    }

    .site-header__logo {
      grid-column: 1;
    }

    .site-header__nav {
      grid-column: 2;
    }

    .site-header__links {
      gap: var(--space-4);
    }
  }
</style>

<script>
  const apply = (experimental: boolean) => {
    document.documentElement.dataset.theme = experimental ? "experimental" : "";
  };

  function init() {
    apply(localStorage.getItem("theme") === "experimental");

    document.body.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).id === "theme-toggle") {
        const next = document.documentElement.dataset.theme !== "experimental";
        apply(next);
        localStorage.setItem("theme", next ? "experimental" : "");
      }
    });
  }

  document.addEventListener("astro:page-load", init);
</script>
