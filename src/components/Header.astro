---
import { SITE_TITLE } from "../config";
import hamburgerIcon from "../assets/noun-hamburger-menu-5434658.svg?raw";

const navLinks = [
  { href: "/work", label: "Work" },
  { href: "/about", label: "Studio" },
  { href: "#", label: "Blog", isExternal: true },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__shell layout-shell">
    <div class="site-header__grid layout-grid">
      <a href="/" class="site-header__logo" aria-label={`${SITE_TITLE} home`}
        >{SITE_TITLE} STUDIO<span class="site-header__logo-dot">.</span></a
      >
      <nav class="site-header__nav" aria-label="Main navigation">
        <ul class="site-header__links">
          {
            navLinks.map(({ href, label, isExternal }) => (
              <li>
                <a
                  href={href}
                  class:list={[
                    "site-header__link",
                    { "site-header__link--active": currentPath === href },
                  ]}
                >
                  <span>{label}</span>
                  {isExternal && (
                    <span
                      class="site-header__external-indicator"
                      aria-hidden="true"
                    >
                      ↗
                    </span>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
        <button
          type="button"
          class="site-header__theme-toggle"
          data-theme-toggle
          aria-label="Toggle experimental theme"></button>
      </nav>
      <button
        type="button"
        class="site-header__menu-trigger"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <Fragment set:html={hamburgerIcon} />
      </button>
    </div>
  </div>
</header>

<nav id="mobile-nav" class="site-header__mobile-nav" aria-label="Mobile navigation" aria-hidden="true">
  <ul class="site-header__links site-header__links--mobile">
    {
      navLinks.map(({ href, label, isExternal }) => (
        <li class="site-header__mobile-nav-item">
          <a
            href={href}
            class:list={[
              "site-header__link",
              { "site-header__link--active": currentPath === href },
            ]}
          >
            <span>{label}</span>
            {isExternal && (
              <span
                class="site-header__external-indicator"
                aria-hidden="true"
              >
                ↗
              </span>
            )}
          </a>
        </li>
      ))
    }
  </ul>
  <div class="site-header__mobile-nav-item">
    <button
      type="button"
      class="site-header__theme-toggle site-header__theme-toggle--mobile"
      data-theme-toggle
      aria-label="Toggle experimental theme"></button>
  </div>
</nav>

<style>
  .site-header {
    background-color: transparent;
    position: relative;
    z-index: 2;
  }

  .site-header__shell {
    padding-block: var(--space-4);
  }

  .site-header__grid {
    align-items: center;
  }

  /* Logo: columns 1–2 */
  .site-header__logo {
    grid-column: 3 / 5;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    text-decoration: none;
    line-height: 1;
  }

  .site-header__logo-dot {
    color: var(--color-accent-experimental);
  }

  /* Nav: columns 7–12, right-aligned */
  .site-header__nav {
    grid-column: 5 / 11;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-6);
  }

  .site-header__links {
    display: flex;
    gap: var(--space-8);
    list-style: none;
  }

  .site-header__link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-1);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.1s ease;
  }

  .site-header__link--active {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .site-header__logo:hover {
      color: var(--color-text-primary);
      text-decoration: none;
    }

    .site-header__link:hover {
      color: var(--color-text-primary);
      text-decoration: none;
    }
  }

  .site-header__external-indicator {
    font-size: 0.95em;
    line-height: 1;
    transform: translateY(-0.08em);
  }

  .site-header__theme-toggle {
    width: 20px;
    height: 20px;
    border-radius: var(--border-radius-full);
    background-color: var(--button-theme-toggle-color);
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.15s ease;
  }

  .site-header__menu-trigger {
    display: none;
  }

  .site-header__mobile-nav {
    display: none; /* hidden on desktop */
  }

  @media (max-width: 768px) {
    .site-header__grid {
      grid-template-columns: 1fr;
      row-gap: var(--space-3);
    }

    .site-header__logo {
      grid-column: 1;
    }

    .site-header__nav {
      display: flex;
      grid-column: 1;
      justify-content: flex-start;
      flex-wrap: wrap;
      gap: var(--space-4);
    }

    .site-header__links {
      gap: var(--space-4);
      flex-wrap: wrap;
    }
  }

  @media (max-width: 768px) {
    .site-header__grid {
      grid-template-columns: 1fr auto;
      row-gap: 0;
    }

    .site-header__nav {
      display: none;
    }

    .site-header__menu-trigger {
      display: inline-flex;
      grid-column: 2;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      padding: 0;
      background: transparent;
      color: var(--color-text-primary);
      border: none;
      cursor: pointer;
      z-index: 1001;
      position: relative;
    }

    .site-header__menu-trigger :global(svg) {
      width: var(--font-size-base);
      height: var(--font-size-base);
      fill: currentColor;
      display: block;
    }

    /* Full-screen overlay — always rendered, opacity/pointer-events control visibility */
    .site-header__mobile-nav {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: var(--space-8);
      position: fixed;
      inset: 0;
      padding: var(--space-16) var(--space-container-x);
      background-color: var(--color-background);
      z-index: 100;
      pointer-events: none;

      /* Closed state */
      opacity: 0;
      transform: translateY(-12px);
      filter: blur(6px);
      transition-property: opacity, transform, filter;
      transition-duration: 180ms;
      transition-timing-function: cubic-bezier(0.4, 0, 1, 1);
    }

    .site-header__mobile-nav.is-open {
      pointer-events: auto;
      opacity: 1;
      transform: translateY(0);
      filter: blur(0px);
      transition-duration: 280ms;
      transition-timing-function: var(--motion-ease-decelerate);
    }

    /* Stagger items */
    .site-header__mobile-nav-item {
      opacity: 0;
      transform: translateY(16px);
      filter: blur(4px);
      transition-property: opacity, transform, filter;
      transition-duration: 180ms;
      transition-timing-function: cubic-bezier(0.4, 0, 1, 1);
    }

    .site-header__mobile-nav.is-open .site-header__mobile-nav-item {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0px);
      transition-duration: 350ms;
      transition-timing-function: var(--motion-ease-decelerate);
    }

    .site-header__mobile-nav.is-open .site-header__mobile-nav-item:nth-child(1) { transition-delay: 60ms; }
    .site-header__mobile-nav.is-open .site-header__mobile-nav-item:nth-child(2) { transition-delay: 110ms; }
    .site-header__mobile-nav.is-open .site-header__mobile-nav-item:nth-child(3) { transition-delay: 160ms; }
    .site-header__mobile-nav.is-open .site-header__mobile-nav-item:nth-child(4) { transition-delay: 210ms; }

    .site-header__mobile-nav {
      align-items: center;
    }

    .site-header__links--mobile {
      flex-direction: column;
      gap: 0;
    }

    .site-header__links--mobile .site-header__link {
      color: var(--color-text-primary);
      font-size: clamp(3.5rem, 18vw, 6rem);
      font-weight: var(--font-weight-bold);
      letter-spacing: -0.03em;
      text-transform: uppercase;
      padding-block: var(--space-4);
      line-height: var(--line-height-tight);
    }

    .site-header__theme-toggle--mobile {
      margin-top: var(--space-8);
    }
  }
</style>

<script>
  let cleanup: (() => void) | undefined;

  const syncThemeToggleState = (experimental: boolean) => {
    document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((toggle) => {
      toggle.setAttribute("aria-pressed", experimental ? "true" : "false");
    });
  };

  const applyTheme = (experimental: boolean) => {
    document.documentElement.dataset.theme = experimental ? "experimental" : "";
    syncThemeToggleState(experimental);
  };

  function init() {
    cleanup?.();
    applyTheme(localStorage.getItem("theme") === "experimental");

    const trigger = document.querySelector<HTMLButtonElement>(".site-header__menu-trigger");
    const nav = document.querySelector<HTMLElement>("#mobile-nav");
    const controller = new AbortController();
    const { signal } = controller;

    if (trigger && nav) {
      const header = document.querySelector<HTMLElement>(".site-header");

      const open = () => {
        nav.classList.add("is-open");
        nav.setAttribute("aria-hidden", "false");
        trigger.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
        if (header) header.style.zIndex = "101";
      };

      const close = () => {
        nav.classList.remove("is-open");
        nav.setAttribute("aria-hidden", "true");
        trigger.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
        if (header) header.style.zIndex = "";
      };

      const toggle = () => nav.classList.contains("is-open") ? close() : open();

      trigger.addEventListener("click", toggle, { signal });

      // Close on link click
      nav.querySelectorAll<HTMLAnchorElement>(".site-header__link").forEach((link) => {
        link.addEventListener("click", close, { signal });
      });

      // Close on Escape
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && nav.classList.contains("is-open")) close();
      }, { signal });
    }

    const toggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");
    toggles.forEach((toggle) => {
      toggle.addEventListener(
        "click",
        () => {
          const next = document.documentElement.dataset.theme !== "experimental";
          applyTheme(next);
          localStorage.setItem("theme", next ? "experimental" : "");
        },
        { signal },
      );
    });

    cleanup = () => {
      controller.abort();
      document.body.style.overflow = "";
    };
  }

  document.addEventListener("astro:page-load", init);
  init();
</script>
