---
import { SITE_TITLE } from "../config";

const navLinks = [
  { href: "/work", label: "Work" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Say hello" },
  { href: "#", label: "Blog", isExternal: true },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__shell layout-shell">
    <div class="site-header__grid layout-grid">
      <a href="/" class="site-header__logo" aria-label={`${SITE_TITLE} home`}
        >{SITE_TITLE} STUDIO.</a
      >
      <nav class="site-header__nav" aria-label="Main navigation">
        <ul class="site-header__links">
          {
            navLinks.map(({ href, label, isExternal }) => (
              <li>
                <a
                  href={href}
                  class:list={[
                    "site-header__link",
                    { "site-header__link--active": currentPath === href },
                  ]}
                >
                  <span>{label}</span>
                  {isExternal && (
                    <span
                      class="site-header__external-indicator"
                      aria-hidden="true"
                    >
                      ↗
                    </span>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .site-header {
    background-color: transparent;
  }

  .site-header__shell {
    padding-block: var(--space-4);
  }

  .site-header__grid {
    align-items: center;
  }

  /* Logo: columns 1–2 */
  .site-header__logo {
    grid-column: 1 / 3;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    text-decoration: none;
    line-height: 1;
  }

  .site-header__logo:hover {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  /* Nav: columns 7–12, right-aligned */
  .site-header__nav {
    grid-column: 7 / 13;
    display: flex;
    justify-content: flex-end;
  }

  .site-header__links {
    display: flex;
    gap: var(--space-8);
    list-style: none;
  }

  .site-header__link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-1);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.1s ease;
  }

  .site-header__link:hover,
  .site-header__link--active {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .site-header__external-indicator {
    font-size: 0.95em;
    line-height: 1;
    transform: translateY(-0.08em);
  }

  @media (max-width: 640px) {
    .site-header__grid {
      grid-template-columns: 1fr 1fr;
    }

    .site-header__logo {
      grid-column: 1;
    }

    .site-header__nav {
      grid-column: 2;
    }

    .site-header__links {
      gap: var(--space-4);
    }
  }
</style>
