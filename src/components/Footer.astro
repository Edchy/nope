---
import { SITE_TITLE } from "../config";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__shell layout-shell">
    <div class="site-footer__grid layout-grid">
      <p class="site-footer__copy">© {year} {SITE_TITLE}</p>
      <p class="site-footer__tag">Made with soul. Made by people.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
  }

  .site-footer__shell {
    padding-block: var(--space-6);
  }

  .site-footer__grid {
    align-items: center;
  }

  /* Copyright: columns 1–3 */
  .site-footer__copy {
    grid-column: 1 / 4;
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  /* Tagline: columns 9–12, right-aligned — mirrors nav position */
  .site-footer__tag {
    grid-column: 9 / 13;
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
    text-align: right;
  }

  @media (max-width: 640px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .site-footer__copy,
    .site-footer__tag {
      grid-column: 1;
      text-align: left;
    }
  }
</style>
