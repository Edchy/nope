---
import { SITE_TITLE } from "../config";

const year = new Date().getFullYear();
const footerWordmark = `${SITE_TITLE}${SITE_TITLE}${SITE_TITLE}`;
const footerLetters = [...footerWordmark];
---

<footer class="site-footer">
  <div class="site-footer__shell" data-footer-shell>
    <div class="site-footer__marquee" aria-hidden="true">
      <p class="site-footer__wordmark">
        {
          footerLetters.map((letter, index) => (
            <span
              class="site-footer__letter"
              style={`--footer-letter-index: ${index};`}
              aria-hidden="true"
            >
              {letter}
            </span>
          ))
        }
      </p>
    </div>
    <div class="site-footer__meta" aria-label="Footer details">
      <p class="site-footer__copy">
        <a href="mailto:hello@nope.digital">hello@nope.digital</a>
      </p>
      <p class="site-footer__copy site-footer__copy--center">
        © {year}
        {SITE_TITLE}
      </p>
      <p class="site-footer__tagline">That'll do</p>
    </div>
  </div>
</footer>

<script>
  declare global {
    interface Window {
      __footerRevealBound?: boolean;
    }
  }

  function initFooterReveal() {
    const footerShell = document.querySelector<HTMLElement>(
      "[data-footer-shell]",
    );
    const footerLetters = footerShell?.querySelectorAll<HTMLElement>(
      ".site-footer__letter",
    );

    if (
      !footerShell ||
      !footerLetters?.length ||
      footerShell.dataset.footerReady === "true"
    ) {
      return;
    }

    footerShell.dataset.footerReady = "true";

    if (
      sessionStorage.getItem("footer-revealed") === "true" ||
      window.matchMedia("(max-width: 768px)").matches ||
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      // Leave letters at their CSS default (opacity: 1) — don't touch inline styles
      footerShell.dataset.footerVisible = "true";
      return;
    }

    const footerStyles = getComputedStyle(footerShell);
    const springEasing =
      footerStyles.getPropertyValue("--motion-ease-footer-spring").trim() ||
      "cubic-bezier(0.34, 1.56, 0.64, 1)";
    const duration =
      Number.parseFloat(
        footerStyles.getPropertyValue("--motion-duration-footer-reveal"),
      ) * 1000 || 900;
    const stagger =
      Number.parseFloat(
        footerStyles.getPropertyValue("--footer-letter-stagger"),
      ) || 52;
    const startTransform =
      "translate3d(0, calc(var(--footer-wordmark-offset-y) * -1), 0) rotate(8deg) scale(0.9)";

    footerLetters.forEach((letter) => {
      letter.style.opacity = "0";
      letter.style.transform = startTransform;
    });

    function animateFooterLetters() {
      if (footerShell!.dataset.footerVisible === "true") {
        return;
      }

      footerShell!.dataset.footerVisible = "true";
      sessionStorage.setItem("footer-revealed", "true");

      footerLetters!.forEach((letter, index) => {
        const animation = letter.animate(
          [
            {
              opacity: 0,
              transform: startTransform, // letters start above, clipped by overflow:clip — no scroll height impact
            },
            {
              opacity: 1,
              offset: 0.58,
              transform:
                "translate3d(0, -0.18em, 0) rotate(-2.5deg) scale(1.06)",
            },
            {
              opacity: 1,
              offset: 0.82,
              transform:
                "translate3d(0, 0.08em, 0) rotate(0.8deg) scale(0.985)",
            },
            {
              opacity: 1,
              transform: "translate3d(0, 0, 0) rotate(0deg) scale(1)",
            },
          ],
          {
            duration,
            delay: index * stagger,
            easing: springEasing,
            fill: "forwards",
          },
        );
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            animateFooterLetters();
            observer.disconnect();
            break;
          }
        }
      },
      {
        threshold: 0.35,
        rootMargin: "0px 0px -10% 0px",
      },
    );

    observer.observe(footerShell);
  }

  if (!window.__footerRevealBound) {
    document.addEventListener("astro:page-load", initFooterReveal);
    window.__footerRevealBound = true;
  }

  initFooterReveal();
</script>
